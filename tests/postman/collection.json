              "\r",
              "var jsonResponse = JSON.parse(responseBody);\r",
              "\r",
              "tests[\"Products are  array\"] = Array.isArray(jsonResponse.products);\r",
              "\r",
              "tests[\"Products are not empty\"] = jsonResponse.products.length !== 0;\r",
              "\r",
              "postman.setEnvironmentVariable(\"productId\", jsonResponse.products[0].id);\r",
              ""
