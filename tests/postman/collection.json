          "raw": "{\n\t\"searchPhrase\": \"*\"\n}"
        },
        "url": {
          "raw": "{{domain}}{{endpoint_catalog_products_get}}",
          "host": [
            "{{domain}}{{endpoint_catalog_products_get}}"
          ]
        },
        "description": "Call getProducts_v1 pipeline to find and extract a product to make further tests on it.\nStore found productId to ENV variable `productId`"
